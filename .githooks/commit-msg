#!/usr/bin/env bash
set -euo pipefail
msg_file="$1"
first_line=$(head -n1 "$msg_file")

if ! echo "$first_line" | grep -Eq '^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-zA-Z0-9._/-]+\))?!?: .+'; then
  echo "commit-msg: use Conventional Commit format, e.g. feat(auth): add login validation" >&2
  exit 1
fi
