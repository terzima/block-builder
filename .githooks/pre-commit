#!/usr/bin/env bash
set -euo pipefail

if git diff --cached --name-only | grep -Ev '^\.env\.example$' | grep -E '(^|/)\.env(\.|$)|\.pem$|\.key$|id_rsa|id_ed25519' >/dev/null; then
  echo "pre-commit: refusing to commit likely secret file" >&2
  exit 1
fi

# Block very large staged files by default.
while IFS= read -r file; do
  [ -f "$file" ] || continue
  size=$(wc -c < "$file" | tr -d ' ')
  if [ "$size" -gt 1048576 ]; then
    echo "pre-commit: refusing to commit file >1MiB: $file" >&2
    echo "Use Git LFS or document why this belongs in the repo." >&2
    exit 1
  fi
done < <(git diff --cached --name-only --diff-filter=ACM)

# Simple secret pattern scan on staged text.
if git diff --cached --unified=0 | grep -E '(AKIA[0-9A-Z]{16}|ghp_[A-Za-z0-9_]{36,}|sk-[A-Za-z0-9]{20,}|BEGIN (RSA |OPENSSH |EC )?PRIVATE KEY)' >/dev/null; then
  echo "pre-commit: possible secret detected in staged diff" >&2
  exit 1
fi

exit 0
